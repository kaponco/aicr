set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${SCRIPT_DIR}"

# OLM olm.sh requires a mode parameter
if [[ $# -eq 0 ]]; then
  echo "Error: Missing required parameter"
  echo "Usage: $0 {subscribe|unsubscribe|apply|delete}"
  echo "  subscribe   - Install OLM operator (Subscription, OperatorGroup)"
  echo "  unsubscribe - Uninstall OLM operator and resources"
  echo "  apply       - Apply custom resources"
  echo "  delete      - Delete custom resources"
  exit 1
fi

MODE="${1}"

case "${MODE}" in
  subscribe)
    # Install OLM operator (Subscription, OperatorGroup)
    echo "Installing {{ .Name }} operator subscription"

    # Create namespace
    echo "Creating namespace {{ .Namespace }}"
    oc create namespace {{ .Namespace }} --dry-run=client -o yaml | oc apply -f - ${KUBECONFIG_FLAG:-}

    # Apply subscription manifests
    echo "Applying install.yaml"
    oc apply --namespace {{ .Namespace }} -f install.yaml ${DRY_RUN_FLAG:-} ${KUBECONFIG_FLAG:-}

    echo "✓ {{ .Name }} operator subscription installed"
    ;;

  apply)
    # Apply custom resources
    # Note: Operator must be installed first via 'olm.sh subscribe'
{{- if .ResourcesFile }}
    echo "Applying {{ .Name }} custom resources"
    oc apply --namespace {{ .Namespace }} -f {{ .ResourcesFileName }} ${DRY_RUN_FLAG:-} ${KUBECONFIG_FLAG:-}
    echo "✓ {{ .Name }} resources applied"
{{- else }}
    echo "No custom resources to apply for {{ .Name }}"
{{- end }}
    ;;

  delete)
    # Delete custom resources
{{- if .ResourcesFile }}
    echo "Deleting {{ .Name }} custom resources"
    oc delete --namespace {{ .Namespace }} -f {{ .ResourcesFileName }} --ignore-not-found --timeout=60s ${KUBECONFIG_FLAG:-}
    echo "✓ {{ .Name }} resources deleted"
{{- else }}
    echo "No custom resources to delete for {{ .Name }}"
{{- end }}
    ;;

  unsubscribe)
    # Uninstall OLM operator
    echo "Uninstalling {{ .Name }} operator"

{{- if .ResourcesFile }}
    # Delete custom resources first
    echo "Deleting {{ .Name }} custom resources"
    oc delete --namespace {{ .Namespace }} -f {{ .ResourcesFileName }} --ignore-not-found --timeout=60s ${KUBECONFIG_FLAG:-}
{{- end }}

    # Get CSV name before deleting subscription
    CSV_NAME=$(oc get -f install.yaml --namespace {{ .Namespace }} ${KUBECONFIG_FLAG:-} -o jsonpath='{.items[?(@.kind=="Subscription")].status.currentCSV}' 2>/dev/null || echo "")

    # Delete subscription and operator group
    echo "Deleting {{ .Name }} subscription"
    oc delete --namespace {{ .Namespace }} -f install.yaml --ignore-not-found ${KUBECONFIG_FLAG:-}

    # Delete CSV if found
    if [ -n "$CSV_NAME" ]; then
      echo "Deleting CSV $CSV_NAME"
      oc delete csv "$CSV_NAME" --namespace {{ .Namespace }} --ignore-not-found --timeout=60s ${KUBECONFIG_FLAG:-}
    fi

    echo "✓ {{ .Name }} operator uninstalled"
    echo "Note: Namespace {{ .Namespace }} preserved (delete manually if needed)"
    ;;

  *)
    echo "Error: Invalid parameter '${MODE}'"
    echo "Usage: $0 {subscribe|unsubscribe|apply|delete}"
    echo "  subscribe   - Install OLM operator (Subscription, OperatorGroup)"
    echo "  unsubscribe - Uninstall OLM operator and resources"
    echo "  apply       - Apply custom resources"
    echo "  delete      - Delete custom resources"
    exit 1
    ;;
esac
