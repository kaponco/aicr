#!/usr/bin/env bash
set -euo pipefail

# OLM Components Uninstallation Script
# Generated by AICR Bundler {{ .BundlerVersion }}
#
# This script uninstalls OLM (Operator Lifecycle Manager) operators by:
#   1. Deleting the Subscription and OperatorGroup manifests
#   2. Deleting the ClusterServiceVersion (CSV)
#   3. Deleting the operator namespace
#
# Usage: ./unsubscribe.sh

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "==> Uninstalling OLM Components"
echo ""

# Uninstall in reverse order (dependencies last) to avoid breaking dependent operators
{{- $components := .OLMComponents }}
{{- $count := len $components }}
{{- range $i := until $count }}
{{- $idx := sub (sub $count 1) $i }}
{{- $comp := index $components $idx }}

echo "==> Uninstalling {{ $comp.Name }}"

# Delete custom resources first to allow operator cleanup
if [ -f "${SCRIPT_DIR}/{{ $comp.Name }}/resources.yaml" ]; then
  echo "    Deleting custom resources for {{ $comp.Name }}"
  kubectl delete -f "${SCRIPT_DIR}/{{ $comp.Name }}/resources.yaml" --ignore-not-found --timeout=60s
fi

# Delete OLM installation manifests (Subscription, OperatorGroup)
echo "    Deleting {{ $comp.Name }}/install.yaml"
kubectl delete -f "${SCRIPT_DIR}/{{ $comp.Name }}/install.yaml" --ignore-not-found

# Delete CSV (ClusterServiceVersion) for this specific operator
# Note: This targets CSVs in the component's namespace only
echo "    Waiting for CSV cleanup in namespace {{ $comp.Namespace }}"
kubectl wait csv --all --for=delete -n {{ $comp.Namespace }} --timeout=60s 2>/dev/null || true

echo "    ✓ {{ $comp.Name }} uninstalled"
echo ""
{{- end }}

# Note: Namespaces are NOT automatically deleted to prevent accidental removal
# of shared namespaces. Delete manually if needed:
{{- range .OLMComponents }}
# kubectl delete namespace {{ .Namespace }} --ignore-not-found
{{- end }}

echo "==> OLM Operators Uninstallation Complete"
echo ""
echo "Note:"
echo "  - Custom resources must be deleted separately via ./undeploy.sh or manually"
