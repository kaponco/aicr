#!/usr/bin/env bash
set -euo pipefail

# OLM Components Uninstallation Script
# Generated by AICR Bundler {{ .BundlerVersion }}
#
# This script uninstalls OLM (Operator Lifecycle Manager) operators by:
#   1. Deleting the Subscription and OperatorGroup manifests
#   2. Deleting the ClusterServiceVersion (CSV)
#   3. Deleting the operator namespace
#
# Usage: ./unsubscribe.sh

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "==> Uninstalling OLM Components"
echo ""

# Uninstall in reverse order (dependencies last) to avoid breaking dependent operators
# Note: Components list is already reversed by the generator
{{- range .OLMComponents }}

echo "==> Uninstalling {{ .Name }}"

# Get CSV name from Subscription before deleting
CSV_NAME=$(kubectl get -f "${SCRIPT_DIR}/{{ .Name }}/install.yaml" -n {{ .Namespace }} -o jsonpath='{.items[?(@.kind=="Subscription")].status.currentCSV}' 2>/dev/null || echo "")

# Delete custom resources first to allow operator cleanup
{{- if .ResourcesFileName }}
if [ -f "${SCRIPT_DIR}/{{ .Name }}/{{ .ResourcesFileName }}" ]; then
  echo "    Deleting custom resources for {{ .Name }}"
  kubectl delete -f "${SCRIPT_DIR}/{{ .Name }}/{{ .ResourcesFileName }}" -n {{ .Namespace }} --ignore-not-found --timeout=60s
fi
{{- end }}

# Delete OLM installation manifests (Subscription, OperatorGroup)
echo "    Deleting {{ .Name }}/install.yaml"
kubectl delete -f "${SCRIPT_DIR}/{{ .Name }}/install.yaml" -n {{ .Namespace }} --ignore-not-found

# Delete the specific CSV if found
if [ -n "$CSV_NAME" ]; then
  echo "    Deleting CSV $CSV_NAME in namespace {{ .Namespace }}"
  kubectl delete csv "$CSV_NAME" -n {{ .Namespace }} --ignore-not-found --timeout=60s
else
  echo "    Warning: Could not determine CSV name for {{ .Name }}"
fi

echo "    ✓ {{ .Name }} uninstalled"
echo ""
{{- end }}

# Note: Namespaces are NOT automatically deleted to prevent accidental removal
# of shared namespaces. Delete manually if needed:
{{- range .OLMComponents }}
# kubectl delete namespace {{ .Namespace }} --ignore-not-found
{{- end }}

echo "==> OLM Operators Uninstallation Complete"
echo ""
echo "Note:"
echo "  - Namespaces are preserved and can be deleted manually if needed"
