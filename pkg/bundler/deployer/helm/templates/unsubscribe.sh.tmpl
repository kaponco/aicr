#!/usr/bin/env bash
set -euo pipefail

# OLM Components Uninstallation Script
# Generated by AICR Bundler {{ .BundlerVersion }}
#
# This script uninstalls OLM (Operator Lifecycle Manager) operators by calling
# each component's olm.sh with 'unsubscribe' mode in reverse order.
#
# Usage: ./unsubscribe.sh

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Export env vars for component olm.sh scripts
export KUBECONFIG_FLAG="${KUBECONFIG_FLAG:-}"

echo "==> Uninstalling OLM Operators"
echo ""

# Collect OLM component folders
OLM_DIRS=()
for dir in "${SCRIPT_DIR}"/[0-9][0-9][0-9]-*/; do
  [[ -d "${dir}" ]] || continue
  # Check if this is an OLM component (has olm.sh)
  if [[ -f "${dir}olm.sh" ]]; then
    OLM_DIRS+=("${dir%/}")
  fi
done

# Uninstall in reverse order (dependencies last) to avoid breaking dependent operators
for ((i=${#OLM_DIRS[@]}-1; i>=0; i--)); do
  dir="${OLM_DIRS[$i]}"
  base="${dir##*/}"
  name="${base#[0-9][0-9][0-9]-}"

  echo "==> Uninstalling ${name} operator"

  # Call component's olm.sh in unsubscribe mode
  if ( cd "${dir}" && bash olm.sh unsubscribe ); then
    echo ""
  else
    echo "ERROR: Failed to uninstall ${name} operator"
    exit 1
  fi
done

echo "==> OLM Operators Uninstallation Complete"
echo ""
echo "Note:"
echo "  - Namespaces are preserved and can be deleted manually if needed"
