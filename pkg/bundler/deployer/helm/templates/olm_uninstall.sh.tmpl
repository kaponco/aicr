#!/usr/bin/env bash
set -euo pipefail

# OLM Components Uninstallation Script
# Generated by AICR Bundler {{ .BundlerVersion }}
#
# This script uninstalls OLM (Operator Lifecycle Manager) operators by:
#   1. Deleting the Subscription and OperatorGroup manifests
#   2. Optionally deleting the operator namespace
#
# Usage: ./olm_uninstall.sh [--delete-namespaces]
#   --delete-namespaces  Also delete operator namespaces (default: keep namespaces)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DELETE_NAMESPACES=false

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --delete-namespaces)
      DELETE_NAMESPACES=true
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [--delete-namespaces]"
      exit 1
      ;;
  esac
done

echo "==> Uninstalling OLM Components"
echo ""

# Uninstall in reverse order (dependencies first)
{{- range .OLMComponents }}

echo "==> Uninstalling {{ .Name }}"

# Delete OLM installation manifests
echo "    Deleting {{ .Name }}/olm/install.yaml"
kubectl delete -f "${SCRIPT_DIR}/{{ .Name }}/olm/install.yaml" --ignore-not-found

if [[ "${DELETE_NAMESPACES}" == "true" ]]; then
  echo "    Deleting namespace {{ .Namespace }}"
  kubectl delete namespace {{ .Namespace }} --ignore-not-found
fi

echo "    ✓ {{ .Name }} uninstalled"
echo ""
{{- end }}

echo "==> OLM Operators Uninstallation Complete"
echo ""
echo "Note:"
echo "  - Namespaces were preserved (use --delete-namespaces to remove them)"
echo "  - Custom resources must be deleted separately via ./undeploy.sh or manually"
