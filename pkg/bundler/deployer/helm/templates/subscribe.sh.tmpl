#!/usr/bin/env bash
set -euo pipefail

# OLM Components Installation Script
# Generated by AICR Bundler {{ .BundlerVersion }}
#
# This script installs OLM (Operator Lifecycle Manager) operators by calling
# each component's olm.sh with 'subscribe' mode.
#
# Usage: ./subscribe.sh

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Export env vars for component olm.sh scripts
export DRY_RUN_FLAG="${DRY_RUN_FLAG:-}"
export KUBECONFIG_FLAG="${KUBECONFIG_FLAG:-}"

echo "==> Installing OLM Operator Subscriptions"
echo ""

# Iterate through numbered folders containing OLM components
for dir in "${SCRIPT_DIR}"/[0-9][0-9][0-9]-*/; do
  [[ -d "${dir}" ]] || continue

  # Check if this is an OLM component (has olm.sh)
  if [[ ! -f "${dir}olm.sh" ]]; then
    continue
  fi

  dir="${dir%/}"
  base="${dir##*/}"
  name="${base#[0-9][0-9][0-9]-}"

  echo "==> Installing ${name} operator subscription"

  # Call component's olm.sh in subscribe mode
  if ( cd "${dir}" && bash olm.sh subscribe ); then
    echo ""
  else
    echo "ERROR: Failed to install ${name} operator subscription"
    exit 1
  fi
done

echo "==> OLM Operator Subscriptions Installation Complete"
echo ""
echo "Next steps:"
echo "  1. Wait for operators to be ready:"
{{- range .OLMComponents }}
echo "     oc wait --namespace {{ .Namespace }} --for=jsonpath='{.status.phase}'=Succeeded csv --all --timeout=5m"
{{- end }}
echo ""
echo "  2. Verify operators are installed:"
{{- range .OLMComponents }}
echo "     oc get csv --namespace {{ .Namespace }}"
{{- end }}
echo ""
echo "  3. Deploy custom resources:"
echo "     ./deploy.sh"
