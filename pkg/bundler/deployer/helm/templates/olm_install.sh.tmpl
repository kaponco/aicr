#!/usr/bin/env bash
set -euo pipefail

# OLM Components Installation Script
# Generated by AICR Bundler {{ .BundlerVersion }}
#
# This script installs OLM (Operator Lifecycle Manager) operators by:
#   1. Creating the operator namespace
#   2. Applying the Subscription and OperatorGroup manifests
#
# Usage: ./olm_install.sh

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "==> Installing OLM Components"
echo ""

{{- range .OLMComponents }}

echo "==> Installing {{ .Name }}"

# Create namespace
echo "    Creating namespace {{ .Namespace }}"
kubectl create namespace {{ .Namespace }} --dry-run=client -o yaml | kubectl apply -f -

# Apply OLM installation manifests
echo "    Applying {{ .Name }}/olm/install.yaml"
kubectl apply -n {{ .Namespace }} -f "${SCRIPT_DIR}/{{ .Name }}/olm/install.yaml"

echo "    ✓ {{ .Name }} installed"
echo ""
{{- end }}

echo "==> OLM Operators Installation Complete"
echo ""
echo "Next steps:"
echo "  1. Wait for operators to be ready:"
{{- range .OLMComponents }}
echo "     kubectl wait --for=jsonpath='{.status.phase}'=Succeeded csv -n {{ .Namespace }} --all --timeout=5m"
{{- end }}
echo ""
echo "  2. Verify operators are installed:"
echo "     kubectl get csv --all-namespaces"
echo ""
echo "  3. Deploy custom resources and remaining components:"
echo "     ./deploy.sh"
