#!/usr/bin/env bash
set -euo pipefail

# OLM Components Installation Script
# Generated by AICR Bundler {{ .BundlerVersion }}
#
# This script auto-discovers and deploys OLM (Operator Lifecycle Manager) components
# by scanning for component directories with olm/ subdirectories.
#
# Usage: ./olm_install.sh

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "==> Auto-discovering OLM Components"
echo ""

# Find all component directories that have an olm/ subdirectory
OLM_COMPONENTS=()
for comp_dir in "${SCRIPT_DIR}"/*; do
  if [[ -d "${comp_dir}/olm" ]]; then
    comp_name=$(basename "${comp_dir}")
    OLM_COMPONENTS+=("${comp_name}")
  fi
done

if [[ ${#OLM_COMPONENTS[@]} -eq 0 ]]; then
  echo "No OLM components found (no directories with olm/ subdirectories)"
  exit 0
fi

echo "Found ${#OLM_COMPONENTS[@]} OLM component(s): ${OLM_COMPONENTS[*]}"
echo ""

# Process each OLM component
for comp_name in "${OLM_COMPONENTS[@]}"; do
  olm_dir="${SCRIPT_DIR}/${comp_name}/olm"

  echo "==> Installing ${comp_name}"

  # Apply all YAML files in the olm/ directory
  yaml_files=("${olm_dir}"/*.yaml)
  if [[ -e "${yaml_files[0]}" ]]; then
    for yaml_file in "${yaml_files[@]}"; do
      filename=$(basename "${yaml_file}")
      echo "    Applying ${comp_name}/olm/${filename}"
      kubectl apply -f "${yaml_file}"
    done
  else
    echo "    WARNING: No YAML files found in ${comp_name}/olm/"
  fi

  echo "    ✓ ${comp_name} installed"
  echo ""
done

echo "==> OLM Components Deployment Complete"
echo ""
echo "Next steps:"
echo "  1. Verify operators are running:"
echo "     kubectl get csv --all-namespaces"
echo ""
echo "  2. Deploy custom resources (if applicable):"
echo "     See component READMEs for custom resource deployment"
echo ""
echo "  3. Deploy remaining components:"
echo "     ./deploy.sh"
