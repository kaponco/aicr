{{ else -}}
Chart: {{ .Repository }}/{{ .ChartName }}
Version: {{ .Version }}
Namespace: {{ .Namespace }}

## Install

```bash
{{ if .IsOCI -}}
helm upgrade --install {{ .Name }} {{ .Repository }}/{{ .ChartName }} \
  --version {{ .Version }} \
  -n {{ .Namespace }} --create-namespace \
  -f values.yaml \
  -f cluster-values.yaml \
  --wait --timeout 10m
{{ else -}}
helm upgrade --install {{ .Name }} {{ .ChartName }} \
  --repo {{ .Repository }} \
  --version {{ .Version }} \
  -n {{ .Namespace }} --create-namespace \
  -f values.yaml \
  -f cluster-values.yaml \
  --wait --timeout 10m
{{ end -}}
```
{{ if .HasManifests }}
After the chart is installed, apply additional manifests:

```bash
kubectl apply -f manifests/
```
{{ end }}
